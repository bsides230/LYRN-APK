<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="24dp"
    tools:context=".SetupActivity">

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="LYRN Setup"
        android:textSize="24sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="32dp"/>

    <TextView
        android:id="@+id/tvRoleLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Select App Role"
        android:textSize="18sp"
        app:layout_constraintTop_toBottomOf="@id/tvTitle"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="32dp"/>

    <RadioGroup
        android:id="@+id/rgRole"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvRoleLabel"
        android:layout_marginTop="16dp">

        <RadioButton
            android:id="@+id/rbRemote"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Remote (Interactive Control Dashboard)"
            android:checked="true"/>

        <RadioButton
            android:id="@+id/rbScreen"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Screen (Dedicated Display / Viewer)"/>
    </RadioGroup>

    <TextView
        android:id="@+id/tvUrlLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Target URL"
        android:textSize="18sp"
        app:layout_constraintTop_toBottomOf="@id/rgRole"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="32dp"/>

    <EditText
        android:id="@+id/etUrl"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:hint="http://10.0.2.2:8080/"
        android:inputType="textUri"
        app:layout_constraintTop_toBottomOf="@id/tvUrlLabel"
        android:layout_marginTop="8dp"/>

    <Button
        android:id="@+id/btnSave"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:text="Start LYRN"
        app:layout_constraintBottom_toBottomOf="parent"
        android:layout_marginBottom="32dp"/>

</androidx.constraintlayout.widget.ConstraintLayout>
